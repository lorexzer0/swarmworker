# swarmworker configuration reference.
#
# swarmworker reads these from the process environment (it does NOT auto-load a
# .env file). Set them in your shell, your process manager, or use a tool like
# `dotenv`/`direnv` to inject them. All variables are optional; sane defaults are
# used when unset. This file documents what's available.

# Port the HTTP + WebSocket server listens on.
# Default: 8787
PORT=8787

# Where git worktrees for agents are created.
# Default: <app-drive>:\swarmworker-worktrees (same drive as the app).
# Can also be changed at runtime in Settings.
# SWARM_WORKTREE_ROOT=D:\swarmworker-worktrees

# Where swarmworker persists its state (projects, settings, agent metadata).
# Default: ~/.swarmworker
# SWARM_DATA_DIR=

# Path to the `claude` executable, if it isn't on PATH or you want a specific one.
# Default: resolved from PATH.
# SWARM_CLAUDE_EXE=
